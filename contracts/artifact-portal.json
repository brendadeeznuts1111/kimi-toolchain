{
  "schemaVersion": 1,
  "kind": "artifact-portal",
  "name": "artifact-portal",
  "description": "Artifact Portal diagnostic contract — Canvas, Dashboard, Herdr, and serve-probe share BenchmarkApiEnvelope",
  "gates": {
    "artifactPortal": "artifact-portal"
  },
  "diagnostics": {
    "benchmark": {
      "type": "benchmark-diagnostics",
      "canvasId": "benchmark",
      "probeRoute": "/api/effect-benchmark",
      "probeRefreshRoute": "/api/effect-benchmark/refresh",
      "cli": "kimi-doctor --perf-gates --serve-probe",
      "envelope": {
        "schemaVersion": 1,
        "required": [
          "runner",
          "thresholdSource",
          "summary",
          "sparklines",
          "gates.effectBenchmarkGate",
          "metadata",
          "metadata.convergence",
          "metadata.testExecution.changedImportGraph"
        ],
        "runners": ["serve-probe", "kimi-doctor", "dashboard", "artifact-portal"]
      },
      "influences": [
        "card-effect-benchmark",
        "card-perf-harness",
        "card-kimi-doctor",
        "card-bun-test"
      ],
      "companionRoutes": {
        "bunTest": "/api/bun-test",
        "importGraphField": "metadata.testExecution.changedImportGraph"
      }
    },
    "configStatus": {
      "type": "config-status-diagnostics",
      "canvasId": "benchmark",
      "probeRoute": "/api/config-status",
      "cli": "kimi-doctor --gate config-status --save-artifact",
      "envelope": {
        "schemaVersion": 1,
        "required": ["tool", "schemaVersion", "aligned", "gates"],
        "tools": ["config-status"]
      },
      "influences": ["card-config-status"]
    }
  },
  "convergence": {
    "ssot": "src/lib/benchmark-convergence.ts",
    "components": ["canvas", "dashboard", "herdr"],
    "envelopeField": "metadata.convergence",
    "manifestField": "convergedComponents"
  },
  "metadata": {
    "manifest": "src/canvases/benchmark.manifest.ts",
    "probeClient": "src/lib/benchmark-probe-client.ts",
    "registration": "src/lib/artifact-portal.ts",
    "convergence": "src/lib/benchmark-convergence.ts"
  }
}
