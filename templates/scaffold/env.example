# ── Required ──
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
API_KEY=replace_me_in_dot_env

# ── Optional ──
# PORT=0                    # 0 = auto-assign. Override only if needed.
# LOG_LEVEL=info            # debug | info | warn | error
# NODE_ENV=development      # development | test | production
# BUN_RUNTIME_TRANSPILER_CACHE_PATH=./.bun-cache

# ── Card probe (kimi-doctor --probe-cards / --serve-probe) ──
# Port/interval default from dx.config.toml [doctor.probe] (scaffold: 5678 / 15000 ms).
# EXAMPLES_DASHBOARD_URL=http://127.0.0.1:3000
# HERDR_DASHBOARD_URL=http://127.0.0.1:18412
# PROBE_SERVER_HOST=127.0.0.1
# PROBE_SERVER_PORT=9239   # overrides [doctor.probe].port when set

# ── Bun install policy overrides (kimi-doctor --gate bunfig-policy) ──
# Bun merges $HOME/.bunfig.toml with ./bunfig.toml; BUN_CONFIG_* env vars win.
# Set HOME to a project-owned temp path in CI when global bunfig state must be isolated.
# HOME=./.tmp/bun-home
# BUN_CONFIG_REGISTRY=https://registry.npmjs.org
# BUN_CONFIG_TOKEN=replace_me_if_supported_by_your_bun_version
# BUN_CONFIG_YARN_LOCKFILE=0
# BUN_CONFIG_LINK_NATIVE_BINS=0
# BUN_CONFIG_SKIP_SAVE_LOCKFILE=0
# BUN_CONFIG_SKIP_LOAD_LOCKFILE=0
# BUN_CONFIG_SKIP_INSTALL_PACKAGES=0
