# Environment variables — copy to .env and adjust for local development.
# Never commit .env (the pre-commit hook blocks it).
#
# Prefer Bun.secrets for credentials; use env vars only as local dev fallbacks.

# ── Optional ──
KIMI_ARTIFACTS_DIR=var/artifacts          # Gate artifact output directory
# PORT=0                                  # Reserved for future HTTP gate endpoints
# LOG_LEVEL=info                          # debug | info | warn | error
# NODE_ENV=development                    # development | test | production
