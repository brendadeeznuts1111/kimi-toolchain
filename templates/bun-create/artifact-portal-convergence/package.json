{
  "name": "{{name}}",
  "version": "0.0.1",
  "private": true,
  "description": "Artifact Portal convergence workspace — Canvas + Dashboard + Herdr → disk",
  "type": "module",
  "scripts": {
    "postinstall": "bun run scripts/postinstall.ts",
    "portal": "sh scripts/portal.sh",
    "portal:local": "sh scripts/portal.sh --local-only",
    "portal:json": "sh scripts/portal.sh --json",
    "verify": "sh scripts/verify.sh",
    "status": "sh scripts/status.sh",
    "hooks:install": "bash scripts/hooks-install.sh",
    "hooks:doctor": "bash -n scripts/hooks-install.sh && echo '✓ hooks-install shell OK'"
  },
  "bun-create": {
    "postinstall": [
      "echo '>>> Template files copied. Run the explicit postinstall next:'",
      "echo 'bun run scripts/postinstall.ts --help'"
    ],
    "start": {
      "portal:local": "bun run portal:local",
      "verify": "bun run verify",
      "hooks:install": "bun run hooks:install"
    }
  },
  "kimi": {
    "showcase": {
      "id": "artifact-portal-convergence",
      "lane": "runtime",
      "accent": "#a371f7",
      "cards": [
        "card-effect-benchmark",
        "card-perf-harness",
        "card-kimi-doctor"
      ]
    }
  },
  "trustedDependencies": []
}
