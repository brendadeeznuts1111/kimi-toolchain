{
  "name": "kimi-toolchain",
  "version": "0.1.0",
  "description": "Bun-native developer tooling: governance, diagnostics, security, and scaffolding",
  "homepage": "https://github.com/brendadeeznuts1111/kimi-toolchain#readme",
  "bugs": {
    "url": "https://github.com/brendadeeznuts1111/kimi-toolchain/issues"
  },
  "license": "MIT",
  "author": "nolarose",
  "repository": {
    "type": "git",
    "url": "https://github.com/brendadeeznuts1111/kimi-toolchain.git"
  },
  "bin": {
    "kimi-cleanup-legacy": "src/bin/kimi-cleanup-legacy.ts",
    "kimi-cloudflare-access": "src/bin/kimi-cloudflare-access.ts",
    "kimi-config": "src/bin/kimi-config.ts",
    "kimi-context-gen": "src/bin/kimi-context-gen.ts",
    "kimi-debug": "src/bin/kimi-debug.ts",
    "kimi-decision": "src/bin/kimi-decision.ts",
    "kimi-doctor": "src/bin/kimi-doctor.ts",
    "kimi-fix": "src/bin/kimi-fix.ts",
    "kimi-githooks": "src/bin/kimi-githooks.ts",
    "kimi-governance": "src/bin/kimi-governance.ts",
    "kimi-guardian": "src/bin/kimi-guardian.ts",
    "kimi-heal": "src/bin/kimi-heal.ts",
    "kimi-identity": "src/bin/kimi-identity.ts",
    "kimi-memory": "src/bin/kimi-memory.ts",
    "kimi-new": "src/bin/kimi-new.ts",
    "kimi-orphan-kill": "src/bin/kimi-orphan-kill.ts",
    "kimi-release": "src/bin/kimi-release.ts",
    "kimi-resource-governor": "src/bin/kimi-resource-governor.ts",
    "kimi-snapshot": "src/bin/kimi-snapshot.ts",
    "kimi-toolchain": "src/bin/kimi-toolchain.ts",
    "unified-shell-bridge": "src/bin/unified-shell-bridge.ts",
    "herdr-doctor": "src/bin/herdr-doctor.ts",
    "herdr-orchestrator": "src/bin/herdr-orchestrator.ts",
    "herdr-pane": "src/bin/herdr-pane.ts",
    "herdr-project": "src/bin/herdr-project.ts",
    "herdr-spawn": "src/bin/herdr-spawn.ts"
  },
  "files": [
    "src",
    "scripts",
    "skills",
    "templates",
    "herdr-plugin",
    ".oxfmtrc.json",
    ".oxlintrc.json",
    "dx.config.toml",
    "AGENTS.md",
    "CODE_REFERENCES.md",
    "UNIFIED.md",
    "TEMPLATES.md",
    "DEEP-QUALITY.md",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "src/lib/utils.ts",

  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "postinstall": "bun run src/install-hooks/postinstall.ts",
    "toolchain": "bun run src/bin/kimi-toolchain.ts",
    "doctor": "bun run src/bin/kimi-doctor.ts",
    "fix": "bun run src/bin/kimi-fix.ts",
    "new": "bun run src/bin/kimi-new.ts",
    "governance": "bun run src/bin/kimi-governance.ts",
    "test": "bun test --retry=2",
    "test:fast": "bun run scripts/run-tests.ts --fast",
    "test:unit": "bun run scripts/run-tests.ts --fast",
    "test:smoke": "bun run scripts/run-tests.ts --smoke",
    "test:ci": "bun test --coverage --retry=2 --reporter=junit --reporter-outfile=reports/junit.xml",
    "test:flake-hunt": "bun test --rerun-each=5 --seed=0 --timeout=30000 --bail=99999",
    "test:shuffle": "bun test --randomize --rerun-each=5 --seed=0 --timeout=30000 --bail=99999",
    "test:pattern": "bun test --test-name-pattern",
    "test:coverage": "bun run scripts/run-tests.ts --coverage",
    "test:coverage:fast": "bun run scripts/run-tests.ts --fast --coverage",
    "test:coverage:ci": "bun run scripts/run-tests.ts --ci --coverage",
    "check": "bun run scripts/check.ts",
    "check:fast": "bun run scripts/check.ts --fast",
    "check:dry-run": "bun run scripts/check.ts --dry-run",
    "check:staged": "bun run scripts/check.ts --staged",
    "ci:local": "bun run scripts/ci-local.ts",
    "finish-work": "bun run scripts/finish-work.ts",
    "pr:diff": "bun run scripts/pr-diff.ts",
    "pr:status": "bun run scripts/pr-status.ts",
    "docs:sync": "bun run scripts/readme-sync.ts --fix",
    "format": "oxfmt --write -c .oxfmtrc.json src scripts test skills templates src/install-hooks",
    "format:check": "oxfmt --check -c .oxfmtrc.json src scripts test skills templates src/install-hooks",
    "format:check:ci": "oxfmt --check --threads=4 -c .oxfmtrc.json src scripts test skills templates src/install-hooks",
    "lint": "oxlint src test scripts && bun run scripts/lint-banned-terms.ts && bun run scripts/lint-patterns.ts && bun run scripts/lint-test-names.ts && bun run scripts/lint-build-constants.ts && bun run scripts/generate-constants-manifest.ts --check && bun run scripts/lint-constant-parity.ts && bun run scripts/lint-cli-contract.ts",
    "lint:taxonomy-coverage": "bun run scripts/lint-taxonomy-coverage.ts",
    "lint:terms": "bun run scripts/lint-banned-terms.ts",
    "manifest:generate": "bun run scripts/generate-constants-manifest.ts",
    "constants:verify": "bun run scripts/generate-constants-manifest.ts --check",
    "typecheck": "tsc --noEmit",
    "sync": "bun run scripts/sync-to-desktop.ts",
    "sync:verify": "bun run scripts/sync-verify.ts",
    "sync:daemon": "bun run scripts/sync-to-desktop.ts --daemon",
    "push": "bash scripts/push.sh",
    "unify": "bash scripts/unify.sh",
    "verify-workspace": "bash scripts/verify-workspace.sh",
    "cleanup-legacy": "bash scripts/cleanup-legacy-workspace.sh",
    "install-wrappers": "bash scripts/install-bin-wrappers.sh",
    "install-herdr-plugin": "bash scripts/install-herdr-plugin.sh",
    "memory-check": "bash scripts/memory-check.sh",
    "bench": "bun run bench/core.bench.ts",
    "memory-budget": "bun run src/bin/kimi-doctor.ts --memory-budget"
  },
  "dependencies": {
    "effect": "^3.21.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/js-yaml": "^4.0.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14"
}
