{
  "name": "kimi-toolchain",
  "version": "0.1.0",
  "description": "Tier-1380 developer tooling: governance, diagnostics, security, and scaffolding",
  "type": "module",
  "main": "src/lib/utils.ts",
  "bin": {
    "kimi-doctor": "src/bin/kimi-doctor.ts",
    "kimi-fix": "src/bin/kimi-fix.ts",
    "kimi-governance": "src/bin/kimi-governance.ts",
    "kimi-guardian": "src/bin/kimi-guardian.ts",
    "kimi-memory": "src/bin/kimi-memory.ts",
    "kimi-context-gen": "src/bin/kimi-context-gen.ts",
    "kimi-githooks": "src/bin/kimi-githooks.ts",
    "kimi-resource-governor": "src/bin/kimi-resource-governor.ts",
    "kimi-snapshot": "src/bin/kimi-snapshot.ts",
    "kimi-release": "src/bin/kimi-release.ts",
    "kimi-debug": "src/bin/kimi-debug.ts",
    "kimi-orphan-kill": "src/bin/kimi-orphan-kill.ts"
  },
  "files": [
    "src",
    "skills",
    "AGENTS.md",
    "UNIFIED.md",
    "TEMPLATES.md",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "postinstall": "bun run src/hooks/postinstall.ts",
    "doctor": "bun run src/bin/kimi-doctor.ts",
    "fix": "bun run src/bin/kimi-fix.ts",
    "governance": "bun run src/bin/kimi-governance.ts",
    "typecheck": "tsc --noEmit",
    "sync": "bun run scripts/sync-to-desktop.ts",
    "sync:daemon": "bun run scripts/sync-to-desktop.ts --daemon",
    "unify": "bash scripts/unify.sh",
    "install-wrappers": "bash scripts/install-bin-wrappers.sh",
    "memory-check": "bash scripts/memory-check.sh",
    "memory-budget": "bun run src/bin/kimi-doctor.ts --memory-budget"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brendadeeznuts1111/kimi-toolchain.git"
  },
  "bugs": {
    "url": "https://github.com/brendadeeznuts1111/kimi-toolchain/issues"
  },
  "homepage": "https://github.com/brendadeeznuts1111/kimi-toolchain#readme",
  "author": "nolarose",
  "license": "MIT"
}
