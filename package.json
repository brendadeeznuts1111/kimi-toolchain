{
  "name": "kimi-toolchain",
  "version": "1.0.0",
  "description": "Bun-native developer tooling: governance, diagnostics, security, and scaffolding",
  "homepage": "https://github.com/brendadeeznuts1111/kimi-toolchain#readme",
  "bugs": {
    "url": "https://github.com/brendadeeznuts1111/kimi-toolchain/issues"
  },
  "license": "MIT",
  "author": "nolarose",
  "repository": {
    "type": "git",
    "url": "https://github.com/brendadeeznuts1111/kimi-toolchain.git"
  },
  "bin": {
    "kimi-capabilities": "src/bin/kimi-capabilities.ts",
    "kimi-cleanup-legacy": "src/bin/kimi-cleanup-legacy.ts",
    "kimi-cloudflare-access": "src/bin/kimi-cloudflare-access.ts",
    "kimi-context-gen": "src/bin/kimi-context-gen.ts",
    "kimi-contract": "src/bin/kimi-contract.ts",
    "kimi-dashboard-mcp": "src/bin/kimi-dashboard-mcp.ts",
    "kimi-debug": "src/bin/kimi-debug.ts",
    "kimi-decision": "src/bin/kimi-decision.ts",
    "kimi-doctor": "src/bin/kimi-doctor.ts",
    "kimi-error": "src/bin/kimi-error.ts",
    "kimi-fix": "src/bin/kimi-fix.ts",
    "kimi-githooks": "src/bin/kimi-githooks.ts",
    "kimi-governance": "src/bin/kimi-governance.ts",
    "kimi-guardian": "src/bin/kimi-guardian.ts",
    "kimi-heal": "src/bin/kimi-heal.ts",
    "kimi-mcp": "src/bin/kimi-mcp.ts",
    "kimi-memory": "src/bin/kimi-memory.ts",
    "kimi-new": "src/bin/kimi-new.ts",
    "kimi-orphan-kill": "src/bin/kimi-orphan-kill.ts",
    "kimi-release": "src/bin/kimi-release.ts",
    "kimi-resource-governor": "src/bin/kimi-resource-governor.ts",
    "kimi-snapshot": "src/bin/kimi-snapshot.ts",
    "kimi-toolchain": "src/bin/kimi-toolchain.ts",
    "kimi-trace": "src/bin/kimi-trace.ts",
    "kimi-why": "src/bin/kimi-why.ts",
    "unified-shell-bridge": "src/bin/unified-shell-bridge.ts"
  },
  "workspaces": [
    "examples/*"
  ],
  "files": [
    "src",
    "scripts",
    "ci",
    "contracts",
    "docs",
    "skills",
    "templates",
    ".oxfmtrc.json",
    ".oxlintrc.json",
    "dx.config.toml",
    "AGENTS.md",
    "CODE_REFERENCES.md",
    "UNIFIED.md",
    "TEMPLATES.md",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "main": "src/lib/utils.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "postinstall": "bun run src/install-hooks/postinstall.ts",
    "toolchain": "bun run src/bin/kimi-toolchain.ts",
    "kimi": "bun run src/bin/kimi-toolchain.ts",
    "doctor": "bun run src/bin/kimi-doctor.ts",
    "dashboard": "bun run src/bin/kimi-dashboard.ts",
    "dashboard-mcp": "bun run src/bin/kimi-dashboard-mcp.ts",
    "capabilities": "bun run src/bin/kimi-capabilities.ts",
    "contract": "bun run src/bin/kimi-contract.ts",
    "decision": "bun run src/bin/kimi-decision.ts",
    "error": "bun run src/bin/kimi-error.ts",
    "heal": "bun run src/bin/kimi-heal.ts",
    "trace": "bun run src/bin/kimi-trace.ts",
    "why": "bun run src/bin/kimi-why.ts",
    "fix": "bun run src/bin/kimi-fix.ts",
    "new": "bun run src/bin/kimi-new.ts",
    "governance": "bun run src/bin/kimi-governance.ts",
    "mcp": "bun run src/bin/kimi-mcp.ts",
    "test": "bun run scripts/test-run.ts",
    "test:watch": "NODE_ENV=test bun test --watch --isolate",
    "test:unit": "bun run scripts/test-fast.ts",
    "test:fast": "bun run scripts/test-fast.ts",
    "test:integration": "bun run scripts/run-tests.ts --integration",
    "test:smoke": "bun run scripts/run-tests.ts --smoke",
    "test:changed": "bun run scripts/test-changed.ts",
    "test:changed:push": "bun run scripts/test-changed.ts --push",
    "test:changed:watch": "NODE_ENV=test bun test --changed --watch --isolate",
    "test:debug": "NODE_ENV=test bun test --inspect --isolate",
    "test:smol": "bun run scripts/test-fast.ts -- --smol",
    "test:ci": "NODE_ENV=test bun test --timeout 30000 --isolate --parallel --shard=${CI_NODE_INDEX:-1}/${CI_NODE_TOTAL:-1}",
    "test:coverage": "bun run scripts/run-tests.ts --coverage",
    "test:coverage:fast": "bun run scripts/run-tests.ts --fast --coverage",
    "test:coverage:ci": "bun run scripts/run-tests.ts --ci --coverage",
    "check": "bun run scripts/check.ts",
    "check:fast": "bun run scripts/check.ts --fast",
    "check:fast:skip-tests": "bun run scripts/check.ts --fast --skip-tests",
    "check:fast:changed": "bun run scripts/check.ts --fast --changed-only",
    "check:dry-run": "bun run scripts/check.ts --dry-run",
    "check:staged": "bun run scripts/check.ts --staged",
    "check:watch": "bun run scripts/check.ts --watch",
    "check:watch:tests": "bun run scripts/check.ts --watch-tests",
    "ci:pipeline": "bun run scripts/ci-pipeline.ts",
    "ci:impact": "bun run scripts/ci-impact.ts",
    "docs:sync": "bun run scripts/readme-sync.ts --fix",
    "reclassify:failures": "bun run scripts/reclassify-failure-ledger.ts",
    "format": "oxfmt --write .",
    "fix:drift": "bun run format && bun run typecheck",
    "format:check": "oxfmt --check -c .oxfmtrc.json .",
    "format:check:ci": "oxfmt --check --threads=4 -c .oxfmtrc.json .",
    "lint": "bun run scripts/lint.ts",
    "quality:check:ci": "oxfmt --check --threads=4 -c .oxfmtrc.json . && oxlint src test scripts && bun run scripts/lint-banned-terms.ts && bun run scripts/lint-patterns.ts && bun run scripts/lint-discovery.ts",
    "lint:terms": "bun run scripts/lint-banned-terms.ts",
    "lint:links": "bun run scripts/lint-markdown-links.ts",
    "lint:links:full": "bun run scripts/lint-markdown-links.ts --full",
    "lint:links:online": "bun run scripts/lint-markdown-links.ts --full --online",
    "typecheck": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "sync": "bun run scripts/sync-to-desktop.ts",
    "sync:check": "bun run sync && bun run sync:verify",
    "sync:manifest": "bun run scripts/sync-manifest.ts",
    "sync:verify": "bun run scripts/sync-manifest.ts --verify",
    "sync:daemon": "bun run scripts/sync-to-desktop.ts --daemon",
    "references:generate": "bun run scripts/generate-canonical-references.ts",
    "push": "bash scripts/push.sh",
    "unify": "bash scripts/unify.sh",
    "verify-workspace": "bash scripts/verify-workspace.sh",
    "cleanup-legacy": "bash scripts/cleanup-legacy-workspace.sh",
    "cleanup:artifacts": "bun run scripts/cleanup-artifacts.ts",
    "install-wrappers": "bash scripts/install-bin-wrappers.sh",
    "memory-check": "bash scripts/memory-check.sh",
    "bench": "bun run bench/core.bench.ts",
    "memory-budget": "bun run src/bin/kimi-doctor.ts --memory-budget",
    "dx:table": "bun run scripts/dx-table.ts",
    "dx:table:contract": "bun run scripts/dx-table-contract.ts",
    "canvas:generate": "bun run scripts/generate-canvas-companions.ts",
    "sync:cursor-canvases": "bun run scripts/sync-cursor-canvases.ts",
    "serve-probe": "bun run src/bin/kimi-doctor.ts --perf-gates --serve-probe",
    "build:portal": "bun run scripts/build-portal.ts",
    "build:portal:local": "bun run scripts/build-portal.ts --local-only",
    "build:portal:json": "bun run scripts/build-portal.ts --json",
    "build:portal:local:json": "bun run scripts/build-portal.ts --local-only --json",
    "build:portal:dry-run": "bun run scripts/build-portal.ts --dry-run",
    "test:gates": "bun test test/portal-convergence.unit.test.ts",
    "bun-install:status": "bun run scripts/bun-install-status.ts",
    "test:portal-convergence": "bun test test/portal-convergence.unit.test.ts",
    "test:portal-convergence:fast": "bun test test/portal-convergence.unit.test.ts -t serve-probe",
    "test:portal-convergence:watch": "NODE_ENV=test bun test --watch --isolate ./test/portal-convergence.unit.test.ts -t serve-probe",
    "finish-work": "bun run scripts/finish-work.ts",
    "discover": "bun run scripts/discover.ts",
    "discover:constants": "bun run scripts/discover.ts --constants",
    "discover:dx": "bun run scripts/discover.ts --dx"
  },
  "dependencies": {
    "effect": "^3.21.3",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/js-yaml": "^4.0.9",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "ts-morph": "^25.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "kimi": {
    "canonicalReferences": "canonical-references.json"
  }
}
