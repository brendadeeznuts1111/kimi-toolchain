#!/bin/sh
# .kimi-code/src/githooks/pre-push
# Enhanced from current pre-commit

# Existing: env block + TODO check
# . ~/.kimi-code/tools/lib/env-check.sh

# NEW: Lockfile integrity
bun run ~/.kimi-code/src/guardian/verify.ts --exit-code
if [ $? -ne 0 ]; then
  echo "🚫 Push blocked: lockfile integrity check failed"
  echo "   Run 'kimi-guardian --sign' if you intentionally modified dependencies"
  exit 1
fi

# NEW: Dependency drift (fast check, not full scan)
bun run ~/.kimi-code/src/drift/check.ts --quick --exit-code
if [ $? -ne 0 ]; then
  echo "⚠️ Push warning: dependency drift detected"
  echo "   Run 'kimi-drift --fix' to update or 'git push --no-verify' to override"
  # Non-blocking for now, make blocking after drift detector matures
fi
