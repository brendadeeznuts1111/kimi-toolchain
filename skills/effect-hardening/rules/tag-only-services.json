{
  "gate": "missing-service-tag",
  "scanner": "src/lib/effect-gates.ts:scanMissingServiceTags",
  "description": "Exported service-shaped classes that import effect must declare Context.Tag and Layer wiring.",
  "requiredPatterns": [
    "class Foo extends Context.Tag(\"Foo\")<Foo, FooService>() {}",
    "Layer.effect or Layer.succeed providing the tag",
    "Test layer with Layer.succeed stubs"
  ],
  "exemptions": [
    "@effect-gates-exempt-service-tag JSDoc on class",
    "classes extending Error or Data.TaggedError"
  ],
  "verify": ["kimi-doctor --effect-gates", "kimi-heal effect audit --check-tags"]
}
