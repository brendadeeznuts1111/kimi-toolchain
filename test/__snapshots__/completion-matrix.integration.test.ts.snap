exports[`completion-matrix integration matrix and dynamic sources are generated from bun-cli.json 1`] = `
{
  "bunVersion": Any<String>,
  "generatedAt": Any<String>,
  "jsonHash": Any<String>,
  "schema": "1.2.0",
  "sources": {
    "add": {
      "completes": [
        "registry_packages",
      ],
      "provider": "getcompletes",
      "providerArgs": [
        "a",
      ],
    },
    "bare_bun": {
      "completes": [
        "files",
        "scripts",
        "binaries",
      ],
      "provider": null,
      "providerArgs": null,
    },
    "build": {
      "completes": [
        "files",
      ],
      "provider": "getcompletes",
      "providerArgs": [
        "j",
      ],
    },
    "create": {
      "completes": [
        "templates",
      ],
      "provider": null,
      "templateDir": "$BUN_INSTALL/create",
    },
    "remove": {
      "completes": [
        "installed_packages",
      ],
      "provider": "getcompletes",
      "providerArgs": [
        "a",
      ],
    },
    "run": {
      "completes": [
        "scripts",
        "files",
        "binaries",
      ],
      "provider": "getcompletes",
      "providerArgs": [
        "s",
        "b",
        "j",
      ],
    },
    "test": {
      "completes": [
        "files",
      ],
      "provider": "getcompletes",
      "providerArgs": [
        "j",
      ],
    },
  },
}
`;

