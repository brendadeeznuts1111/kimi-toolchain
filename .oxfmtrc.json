{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "ignorePatterns": [
    "bun.lock",
    "CHANGELOG.md",
    ".tmp-*",
    "~/.bun",
    ".kimi-artifacts",
    ".kimi/",
    "coverage/",
    "*.log",
    "canonical-references.json",
    "examples/dashboard-urls.md",
    "scripts/.fmt-*",
    ".kimi-test-execve-child.ts"
  ]
}
