# Secrets (pre-commit also blocks; .env.example is tracked)
.env
.env.local
.env.*.local
.env.test

# Project-level Kimi Code config (scaffolded by kimi-fix, not source)
.kimi-code/

# Live runtime state (not tracked)
/tools/
/var/
/memory/
/guardian/
/governor/
node_modules/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# Build artifacts
dist/
.cache/
.kimi-artifacts/
coverage/
reports/
.tmp-kimi-test-home/
scripts/.fmt-*
.tmp-drift-*/
.tmp-test-*/
.tmp-path-align-*/
.tmp/
.tmp-*/
*.log
*.bun-build
.bun-build*

# Compiled binaries (bun build --compile output)
cli
out.js
*.executable

# Machine-trained perf thresholds (portable baseline is thresholds.baseline.json)
/thresholds.json

# Local toolchain / editor runtime (repo root only)
.kimi/
.reasonix/
.bun-create
.bun-native-baseline.json
.cursor/
.codex/
.kimi-test-locks/
test-define-tmp.ts

# Local agent/IDE config (machine-specific, like .env)
reasonix.toml

# Stray home-dir snapshots (accidentally created inside repo root)
~/
Users/

# CPU profiles (generated by --profile flag)
*.cpuprofile

# Editor-specific agent rules (AGENTS.md is the canonical source)
CLAUDE.md

# OS
.DS_Store
profiles/

# Temporary compile-smoke artifacts
*.tmp-compile-smoke.ts
