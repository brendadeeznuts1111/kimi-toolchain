# Copy to .env for local development. Never commit real secrets.
#
# Prefer Bun.secrets for credentials:
#   bun secrets set com.herdr.cli/github-token ghp_xxx
#
# Reverse-domain fallback naming:
#   Bun.secrets key: com.herdr.cli/github-token
#   Env fallback:    COM_HERDR_CLI_GITHUB_TOKEN
#   Transform:       uppercase, "." "/" "-" -> "_"
#
# Bun env loading:
#   Bun auto-loads .env, then .env.$NODE_ENV, then .env.local.
#   Later files override earlier files when the same key is present.
#   Use --env-file=.env.production for explicit files; repeat for multiple files.
#   Use --no-env-file to disable automatic .env loading.
#   bunfig.toml env = false also disables automatic .env loading.
#   Bun.env, process.env, and import.meta.env are aliases.
#   Env values support expansion, for example API_URL=https://$API_HOST.
#   Escape a literal dollar sign as \$API_HOST.

# -- App runtime --------------------------------------------------------
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
API_KEY=xxx_replace_me_in_dot_env
# PORT=0
# LOG_LEVEL=info
# NODE_ENV=development

# -- Bun runtime and diagnostics ---------------------------------------
# BUN_OPTIONS=--smol
# BUN_RUNTIME_TRANSPILER_CACHE_PATH=0
# BUN_RUNTIME_TRANSPILER_CACHE_PATH=./.bun-cache
# BUN_CONFIG_VERBOSE_FETCH=curl
# BUN_CONFIG_VERBOSE_FETCH=1
# BUN_CONFIG_MAX_HTTP_REQUESTS=256
# BUN_CONFIG_NO_CLEAR_TERMINAL_ON_RELOAD=true
# DO_NOT_TRACK=1
# TMPDIR=/tmp

# -- Terminal output ----------------------------------------------------
# NO_COLOR=1
# FORCE_COLOR=1

# -- GitHub / npm publishing -------------------------------------------
# Bun.secrets:    com.herdr.cli/github-token
# Env fallback:   COM_HERDR_CLI_GITHUB_TOKEN
# Format:         ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (40 chars)
# Generate:       https://github.com/settings/tokens
# Used by:        kimi-fix, kimi-release, kimi-governance
# Required:       yes
COM_HERDR_CLI_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.cli/npm-token
# Env fallback:   COM_HERDR_CLI_NPM_TOKEN
# Format:         npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       https://www.npmjs.com/settings/-/tokens
# Used by:        kimi-release, kimi-bake
# Required:       yes
COM_HERDR_CLI_NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.cli/github-api-domain
# Env fallback:   COM_HERDR_CLI_GITHUB_API_DOMAIN
# Format:         https://api.github.com or GitHub Enterprise API URL
# Generate:       n/a
# Used by:        kimi-fix, kimi-release, GitHub API clients
# Required:       no, defaults to https://api.github.com
# COM_HERDR_CLI_GITHUB_API_DOMAIN=https://api.github.com

# -- R2 / artifacts / KPI exports --------------------------------------
# Bun.secrets:    com.herdr.cli/r2-access-key-id
# Env fallback:   COM_HERDR_CLI_R2_ACCESS_KEY_ID
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Cloudflare R2 API token page
# Used by:        KPI exports, artifact upload, report archival
# Required:       yes when R2 exports are enabled
COM_HERDR_CLI_R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.cli/r2-secret-access-key
# Env fallback:   COM_HERDR_CLI_R2_SECRET_ACCESS_KEY
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Cloudflare R2 API token page
# Used by:        KPI exports, artifact upload, report archival
# Required:       yes when R2 exports are enabled
COM_HERDR_CLI_R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Alerting and messaging --------------------------------------------
# Bun.secrets:    com.herdr.cli/discord-webhook-url
# Env fallback:   COM_HERDR_CLI_DISCORD_WEBHOOK_URL
# Format:         https://discord.com/api/webhooks/...
# Generate:       Discord channel integrations
# Used by:        webhook alerts
# Required:       no, only for Discord alerts
COM_HERDR_CLI_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx

# Bun.secrets:    com.herdr.cli/telegram-bot-token
# Env fallback:   COM_HERDR_CLI_TELEGRAM_BOT_TOKEN
# Format:         123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Telegram BotFather
# Used by:        Telegram Hub
# Required:       no, only for Telegram alerts
COM_HERDR_CLI_TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Data providers and commerce integrations --------------------------
# Bun.secrets:    com.herdr.cli/buckeye-api-key
# Env fallback:   COM_HERDR_CLI_BUCKEYE_API_KEY
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Buckeye account dashboard
# Used by:        Sports Terminal
# Required:       no, only for Buckeye-backed sports data
COM_HERDR_CLI_BUCKEYE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.cli/bet365-api-key
# Env fallback:   COM_HERDR_CLI_BET365_API_KEY
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Bet365 provider dashboard
# Used by:        Sports Terminal odds ingestion
# Required:       no, only for Bet365-backed odds data
COM_HERDR_CLI_BET365_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.cli/stripe-secret-key
# Env fallback:   COM_HERDR_CLI_STRIPE_SECRET_KEY
# Format:         Stripe secret key (test or live)
# Generate:       Stripe Developers > API keys
# Used by:        Peptex payments
# Required:       no, only for payments
COM_HERDR_CLI_STRIPE_SECRET_KEY=xxx_stripe_secret_key

# Bun.secrets:    com.herdr.cli/shippo-api-token
# Env fallback:   COM_HERDR_CLI_SHIPPO_API_TOKEN
# Format:         shippo_test_xxx or shippo_live_xxx
# Generate:       Shippo API dashboard
# Used by:        shipping labels
# Required:       no, only for shipping label flows
COM_HERDR_CLI_SHIPPO_API_TOKEN=shippo_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.cli/kalshi-api-key
# Env fallback:   COM_HERDR_CLI_KALSHI_API_KEY
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Kalshi developer settings
# Used by:        prediction markets
# Required:       no, only for Kalshi integrations
COM_HERDR_CLI_KALSHI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.cli/massey-api-key
# Env fallback:   COM_HERDR_CLI_MASSEY_API_KEY
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Massey provider dashboard
# Used by:        line-setting data
# Required:       no, only for Massey integrations
COM_HERDR_CLI_MASSEY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Dashboard server ---------------------------------------------------
# Bun.secrets:    com.herdr.dashboard/jwt-secret
# Env fallback:   COM_HERDR_DASHBOARD_JWT_SECRET
# Format:         32+ random bytes, base64 or hex
# Generate:       openssl rand -base64 32
# Used by:        kimi-dashboard server auth
# Required:       yes for dashboard auth
COM_HERDR_DASHBOARD_JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.dashboard/csrf-secret
# Env fallback:   COM_HERDR_DASHBOARD_CSRF_SECRET
# Format:         32+ random bytes, base64 or hex
# Generate:       openssl rand -base64 32
# Used by:        kimi-dashboard CSRF protection
# Required:       yes for dashboard form/session protection
COM_HERDR_DASHBOARD_CSRF_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.dashboard/master-key
# Env fallback:   COM_HERDR_DASHBOARD_MASTER_KEY
# Format:         32+ random bytes, base64 or hex
# Generate:       openssl rand -base64 32
# Used by:        dashboard administrative flows
# Required:       yes for privileged dashboard operations
COM_HERDR_DASHBOARD_MASTER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional dashboard runtime endpoints.
# HERDR_DASHBOARD_URL=http://127.0.0.1:18412
# HERDR_EXAMPLES_DASHBOARD_URL=http://127.0.0.1:5678

# -- Core services ------------------------------------------------------
# Bun.secrets:    com.herdr.core/service-token
# Env fallback:   COM_HERDR_CORE_SERVICE_TOKEN
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       internal service-token issuer
# Used by:        internal services
# Required:       no, only for core service-to-service flows
COM_HERDR_CORE_SERVICE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Harness / test agents ---------------------------------------------
# Bun.secrets:    com.herdr.harness/agent-token
# Env fallback:   COM_HERDR_HARNESS_AGENT_TOKEN
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       harness control plane
# Used by:        test agents
# Required:       no, only for harness agents
COM_HERDR_HARNESS_AGENT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Metrics / Grafana / KPI exports -----------------------------------
# Bun.secrets:    com.herdr.metrics/grafana-token
# Env fallback:   COM_HERDR_METRICS_GRAFANA_TOKEN
# Format:         glsa_xxx or Grafana service-account token
# Generate:       Grafana service account tokens
# Used by:        Grafana, KPI dashboards
# Required:       no, only for metrics exports
COM_HERDR_METRICS_GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    com.herdr.metrics/r2-kpi-bucket
# Env fallback:   COM_HERDR_METRICS_R2_KPI_BUCKET
# Format:         bucket-name
# Generate:       Cloudflare R2 bucket settings
# Used by:        R2 KPI export target
# Required:       no, only for KPI exports
COM_HERDR_METRICS_R2_KPI_BUCKET=xxx-kpi-bucket

# -- CI-only fallbacks --------------------------------------------------
# Bun.secrets:    com.herdr.ci/github-token
# Env fallback:   COM_HERDR_CI_GITHUB_TOKEN
# Format:         github-actions token or ghp_xxx
# Generate:       GitHub Actions secrets
# Used by:        CI quality gates
# Required:       no for local dev, yes in CI when GitHub API access is needed
# COM_HERDR_CI_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Short aliases supported by secrets-env.ts.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NPM_CONFIG_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- Cloudflare Access legacy service ----------------------------------
# Bun.secrets:    kimi-toolchain/cloudflare-account-id
# Env fallback:   CLOUDFLARE_ACCOUNT_ID
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Cloudflare dashboard
# Used by:        Cloudflare Access tooling
# Required:       no, only for Cloudflare Access flows
# CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bun.secrets:    kimi-toolchain/cloudflare-api-token
# Env fallback:   CLOUDFLARE_API_TOKEN
# Format:         xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Generate:       Cloudflare dashboard
# Used by:        Cloudflare Access tooling
# Required:       no, only for Cloudflare Access flows
# CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

