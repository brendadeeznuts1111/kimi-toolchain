# Copy to .env for local development. Never commit real secrets.
#
# Prefer Bun.secrets for credentials:
#   bun secrets set com.herdr.cli/github-token ghp_xxx
#
# Env fallback naming rule:
#   com.herdr.cli/github-token -> COM_HERDR_CLI_GITHUB_TOKEN
#   reverse-domain service + "/" + secret name, then uppercase and replace . / - with _

# ── App runtime ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
API_KEY=replace_me_in_dot_env
# PORT=0
# LOG_LEVEL=info
# NODE_ENV=development

# ── Bun runtime and diagnostics ───────────────────────────────────────
# BUN_RUNTIME_TRANSPILER_CACHE_PATH=./.bun-cache
# BUN_CONFIG_VERBOSE_FETCH=curl

# ── Terminal output ───────────────────────────────────────────────────
# NO_COLOR=1
# FORCE_COLOR=1

# ── GitHub / npm publishing ───────────────────────────────────────────
# Bun.secrets: com.herdr.cli/github-token
COM_HERDR_CLI_GITHUB_TOKEN=replace_me_github_token

# Bun.secrets: com.herdr.cli/npm-token
COM_HERDR_CLI_NPM_TOKEN=replace_me_npm_token

# Bun.secrets: com.herdr.cli/github-api-domain
# COM_HERDR_CLI_GITHUB_API_DOMAIN=https://api.github.com

# ── R2 / artifacts / KPI exports ──────────────────────────────────────
# Bun.secrets: com.herdr.cli/r2-access-key-id
COM_HERDR_CLI_R2_ACCESS_KEY_ID=replace_me_r2_access_key_id

# Bun.secrets: com.herdr.cli/r2-secret-access-key
COM_HERDR_CLI_R2_SECRET_ACCESS_KEY=replace_me_r2_secret_access_key

# ── Alerting and messaging ────────────────────────────────────────────
# Bun.secrets: com.herdr.cli/discord-webhook-url
COM_HERDR_CLI_DISCORD_WEBHOOK_URL=replace_me_discord_webhook_url

# Bun.secrets: com.herdr.cli/telegram-bot-token
COM_HERDR_CLI_TELEGRAM_BOT_TOKEN=replace_me_telegram_bot_token

# ── Data providers and commerce integrations ─────────────────────────
# Bun.secrets: com.herdr.cli/buckeye-api-key
COM_HERDR_CLI_BUCKEYE_API_KEY=replace_me_buckeye_api_key

# Bun.secrets: com.herdr.cli/bet365-api-key
COM_HERDR_CLI_BET365_API_KEY=replace_me_bet365_api_key

# Bun.secrets: com.herdr.cli/stripe-secret-key
COM_HERDR_CLI_STRIPE_SECRET_KEY=replace_me_stripe_secret_key

# Bun.secrets: com.herdr.cli/shippo-api-token
COM_HERDR_CLI_SHIPPO_API_TOKEN=replace_me_shippo_api_token

# Bun.secrets: com.herdr.cli/kalshi-api-key
COM_HERDR_CLI_KALSHI_API_KEY=replace_me_kalshi_api_key

# Bun.secrets: com.herdr.cli/massey-api-key
COM_HERDR_CLI_MASSEY_API_KEY=replace_me_massey_api_key

# ── Dashboard server ──────────────────────────────────────────────────
# Bun.secrets: com.herdr.dashboard/jwt-secret
COM_HERDR_DASHBOARD_JWT_SECRET=replace_me_dashboard_jwt_secret

# Bun.secrets: com.herdr.dashboard/csrf-secret
COM_HERDR_DASHBOARD_CSRF_SECRET=replace_me_dashboard_csrf_secret

# Bun.secrets: com.herdr.dashboard/master-key
COM_HERDR_DASHBOARD_MASTER_KEY=replace_me_dashboard_master_key

# Optional dashboard runtime endpoints.
# HERDR_DASHBOARD_URL=http://127.0.0.1:18412
# HERDR_EXAMPLES_DASHBOARD_URL=http://127.0.0.1:5678

# ── Core services ─────────────────────────────────────────────────────
# Bun.secrets: com.herdr.core/service-token
COM_HERDR_CORE_SERVICE_TOKEN=replace_me_core_service_token

# ── Harness / test agents ─────────────────────────────────────────────
# Bun.secrets: com.herdr.harness/agent-token
COM_HERDR_HARNESS_AGENT_TOKEN=replace_me_harness_agent_token

# ── Metrics / Grafana / KPI exports ──────────────────────────────────
# Bun.secrets: com.herdr.metrics/grafana-token
COM_HERDR_METRICS_GRAFANA_TOKEN=replace_me_grafana_token

# Bun.secrets: com.herdr.metrics/r2-kpi-bucket
COM_HERDR_METRICS_R2_KPI_BUCKET=replace_me_r2_kpi_bucket

# ── CI-only fallbacks ─────────────────────────────────────────────────
# Bun.secrets: com.herdr.ci/github-token
# COM_HERDR_CI_GITHUB_TOKEN=replace_me_ci_github_token

# Short aliases supported by secrets-env.ts.
# GITHUB_TOKEN=replace_me_github_token
# GH_TOKEN=replace_me_github_token
# NPM_TOKEN=replace_me_npm_token
# NPM_CONFIG_TOKEN=replace_me_npm_token

# ── Cloudflare Access legacy service ─────────────────────────────────
# Bun.secrets: kimi-toolchain/cloudflare-account-id
# CLOUDFLARE_ACCOUNT_ID=replace_me_cloudflare_account_id

# Bun.secrets: kimi-toolchain/cloudflare-api-token
# CLOUDFLARE_API_TOKEN=replace_me_cloudflare_api_token
